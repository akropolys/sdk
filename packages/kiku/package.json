{
  "name": "@akropolys/kiku",
  "version": "1.7.17",
  "description": "The chat and search widgets for Akropolys — the interface your users and their AI agents actually talk to.",
  "license": "MIT",
  "keywords": [
    "akropolys",
    "kiku",
    "ai",
    "chat",
    "search",
    "react",
    "ui",
    "components",
    "ecommerce",
    "shopping-assistant",
    "conversational-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akropolys/sdk.git"
  },
  "homepage": "https://akropolys.io",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "@akropolys/sdk": "^1.8.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@akropolys/sdk": "workspace:*",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  }
}
