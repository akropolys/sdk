{
  "name": "@akropolys/sdk",
  "version": "1.6.0",
  "description": "Intent infrastructure for the web. Auto-ingest, natural language search, and personal AI agent access to your catalog.",
  "license": "MIT",
  "keywords": [
    "akropolys",
    "kiku",
    "ai",
    "search",
    "chat",
    "ecommerce",
    "headless",
    "sdk",
    "streaming",
    "react",
    "nextjs",
    "vector-search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akropolys/sdk.git"
  },
  "homepage": "https://akropolys.io",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
